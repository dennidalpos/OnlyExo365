<UserControl x:Class="ExchangeAdmin.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Dashboard" FontSize="20" FontWeight="SemiBold"/>

            <Button Grid.Column="1" Content="Refresh" Command="{Binding Dashboard.RefreshCommand}"
                    Style="{StaticResource PrimaryButton}"/>
        </Grid>

        
        <Border Grid.Row="1" Background="#3D2200" BorderBrush="{StaticResource WarningBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,16"
                Visibility="{Binding Dashboard.HasWarnings, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="Warnings" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"/>
                <ItemsControl ItemsSource="{Binding Dashboard.Warnings}" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                       Foreground="{StaticResource WarningBrush}" Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            
            <GroupBox Grid.Column="0" Header="Mailboxes" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="User Mailboxes"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Dashboard.UserMailboxCount}" FontWeight="SemiBold"
                               HorizontalAlignment="Right">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Grid.Row="0" Grid.ColumnSpan="2" Command="{Binding NavigateToMailboxesCommand}"
                            Opacity="0" Cursor="Hand" Background="Transparent" BorderThickness="0"/>

                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Shared Mailboxes" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Dashboard.SharedMailboxCount}" FontWeight="SemiBold"
                               HorizontalAlignment="Right" Margin="0,8,0,0" Foreground="{StaticResource InfoBrush}"/>
                    <Button Grid.Row="1" Grid.ColumnSpan="2" Command="{Binding NavigateToSharedMailboxesCommand}"
                            Opacity="0" Cursor="Hand" Background="Transparent" BorderThickness="0"/>

                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Room Mailboxes" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Dashboard.RoomMailboxCount}" FontWeight="SemiBold"
                               HorizontalAlignment="Right" Margin="0,8,0,0" Foreground="{StaticResource InfoBrush}"/>

                    
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Equipment Mailboxes" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Dashboard.EquipmentMailboxCount}" FontWeight="SemiBold"
                               HorizontalAlignment="Right" Margin="0,8,0,0" Foreground="{StaticResource InfoBrush}"/>

                    <Separator Grid.Row="4" Grid.ColumnSpan="2" Margin="0,12,0,8"
                               Background="{StaticResource BorderBrush}"/>

                    
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Total" FontWeight="SemiBold"/>
                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Dashboard.TotalMailboxCount}" FontWeight="Bold" FontSize="18"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="*" Foreground="{StaticResource WarningBrush}"
                                   Visibility="{Binding Dashboard.IsApproximate, Converter={StaticResource BoolToVisibility}}"
                                   ToolTip="Approximate count"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            
            <GroupBox Grid.Column="1" Header="Distribution Groups" Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Distribution Groups"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Dashboard.DistributionGroupCount}" FontWeight="SemiBold"
                               HorizontalAlignment="Right" Foreground="{StaticResource InfoBrush}"/>
                    <Button Grid.Row="0" Grid.ColumnSpan="2" Command="{Binding NavigateToDistributionListsCommand}"
                            Opacity="0" Cursor="Hand" Background="Transparent" BorderThickness="0"/>

                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Dynamic Groups" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Dashboard.DynamicDistributionGroupCount}" FontWeight="SemiBold"
                               HorizontalAlignment="Right" Margin="0,8,0,0" Foreground="{StaticResource InfoBrush}"/>

                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="M365 Groups" Margin="0,8,0,0"
                               Visibility="{Binding Dashboard.ShowUnifiedGroups, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Dashboard.UnifiedGroupCount}" FontWeight="SemiBold"
                               HorizontalAlignment="Right" Margin="0,8,0,0" Foreground="{StaticResource InfoBrush}"
                               Visibility="{Binding Dashboard.ShowUnifiedGroups, Converter={StaticResource BoolToVisibility}}"/>

                    <Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0,12,0,8"
                               Background="{StaticResource BorderBrush}"/>

                    
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Total" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Dashboard.TotalGroupCount}" FontWeight="Bold" FontSize="18"
                               HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}"/>
                </Grid>
            </GroupBox>
        </Grid>

        
        <Grid Grid.Row="3" Margin="0,16,0,0">
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top"
                        Visibility="{Binding Dashboard.IsLoading, Converter={StaticResource BoolToVisibility}}">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Loading statistics..." HorizontalAlignment="Center" Margin="0,8,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>

            
            <Border Background="#3D0000" BorderBrush="{StaticResource ErrorBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Visibility="{Binding Dashboard.HasError, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Error" FontWeight="SemiBold" Foreground="{StaticResource ErrorBrush}"/>
                    <TextBlock Text="{Binding Dashboard.ErrorMessage}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
