<UserControl x:Class="ExchangeAdmin.Presentation.Views.MailboxDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:contracts="clr-namespace:ExchangeAdmin.Contracts.Dtos;assembly=ExchangeAdmin.Contracts">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Back" Command="{Binding BackCommand}"
                    Style="{StaticResource {x:Type Button}}" Margin="0,0,12,0"
                    ToolTip="Return to mailbox list"/>

            <StackPanel Grid.Column="1" Orientation="Vertical">
                <TextBlock Text="{Binding DisplayName, FallbackValue='Mailbox Details'}"
                           FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding PrimarySmtpAddress}"
                           Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
            </StackPanel>

            <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryButton}"
                    ToolTip="Reload mailbox details and permissions"/>
        </Grid>

        <!-- Main Content with ScrollViewer -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Error Message -->
                <Border Background="#3D0000" BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,16"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Error" FontWeight="SemiBold" Foreground="{StaticResource ErrorBrush}"/>
                        <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Loading Indicator -->
                <StackPanel HorizontalAlignment="Center" Margin="0,32,0,16"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                    <TextBlock Text="Loading mailbox details..." HorizontalAlignment="Center" Margin="0,8,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>

                <!-- Details Content -->
                <StackPanel Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibility}}">

                    <!-- Basic Information -->
                    <GroupBox Header="Basic Information" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Display Name:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DisplayName}" TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Primary Email:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PrimarySmtpAddress}" TextWrapping="Wrap" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RecipientTypeDetails}" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="All Addresses:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <ItemsControl Grid.Row="3" Grid.Column="1" ItemsSource="{Binding Details.EmailAddresses}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </GroupBox>

                    <!-- Features -->
                    <GroupBox Header="Features" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Archive -->
                            <CheckBox Grid.Row="0" Grid.Column="0" Content="Archive Enabled"
                                      IsChecked="{Binding Features.ArchiveEnabled, Mode=OneWay}" IsEnabled="False"
                                      ToolTip="Archive mailbox status (read-only)"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Features.ArchiveName}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>

                            <!-- Litigation Hold -->
                            <CheckBox Grid.Row="1" Grid.Column="0" Content="Litigation Hold"
                                      IsChecked="{Binding Features.LitigationHoldEnabled, Mode=OneWay}"
                                      Command="{Binding SetFeatureCommand}"
                                      CommandParameter="{x:Static contracts:MailboxFeature.LitigationHold}"
                                      Margin="0,8,0,0"
                                      ToolTip="Preserves all mailbox content for legal discovery. Click to toggle on/off."/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                                <TextBlock Text="{Binding Features.LitigationHoldDate, StringFormat='{}Since: {0:yyyy-MM-dd}'}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Visibility="{Binding Features.LitigationHoldEnabled, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="{Binding Features.LitigationHoldOwner, StringFormat='{}Owner: {0}'}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Visibility="{Binding Features.LitigationHoldEnabled, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <!-- Audit -->
                            <CheckBox Grid.Row="2" Grid.Column="0" Content="Audit Enabled"
                                      IsChecked="{Binding Features.AuditEnabled, Mode=OneWay}"
                                      Command="{Binding SetFeatureCommand}"
                                      CommandParameter="{x:Static contracts:MailboxFeature.Audit}"
                                      Margin="0,8,0,0"
                                      ToolTip="Tracks mailbox access and actions by users and administrators. Click to toggle on/off."/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding Features.AuditLogAgeLimit, StringFormat='{}Age Limit: {0}'}"
                                       Foreground="{StaticResource SecondaryTextBrush}" Margin="0,8,0,0"/>

                            <!-- Single Item Recovery -->
                            <CheckBox Grid.Row="3" Grid.Column="0" Content="Single Item Recovery"
                                      IsChecked="{Binding Features.SingleItemRecoveryEnabled, Mode=OneWay}"
                                      Command="{Binding SetFeatureCommand}"
                                      CommandParameter="{x:Static contracts:MailboxFeature.SingleItemRecovery}"
                                      Margin="0,8,0,0"
                                      ToolTip="Allows recovery of deleted items beyond retention period. Click to toggle on/off."/>

                            <!-- Retention Hold -->
                            <CheckBox Grid.Row="4" Grid.Column="0" Content="Retention Hold"
                                      IsChecked="{Binding Features.RetentionHoldEnabled, Mode=OneWay}"
                                      Command="{Binding SetFeatureCommand}"
                                      CommandParameter="{x:Static contracts:MailboxFeature.RetentionHold}"
                                      Margin="0,8,0,0"
                                      ToolTip="Suspends retention policy processing for this mailbox. Click to toggle on/off."/>

                            <!-- Forwarding -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Forwarding:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,8,0,0">
                                <TextBlock Text="{Binding Features.ForwardingSmtpAddress, StringFormat='{}To: {0}'}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Visibility="{Binding Features.ForwardingSmtpAddress, Converter={StaticResource NullToVisibility}}"/>
                                <TextBlock Text="{Binding Features.ForwardingAddress, StringFormat='{}To: {0}'}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Visibility="{Binding Features.ForwardingAddress, Converter={StaticResource NullToVisibility}}"/>
                                <CheckBox Content="Deliver to Mailbox and Forward"
                                          IsChecked="{Binding Features.DeliverToMailboxAndForward, Mode=OneWay}"
                                          IsEnabled="False" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Quotas -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Quotas:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <StackPanel Grid.Row="6" Grid.Column="1" Margin="0,8,0,0">
                                <TextBlock Text="{Binding Features.IssueWarningQuota, StringFormat='{}Warning: {0}'}"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding Features.ProhibitSendQuota, StringFormat='{}Prohibit Send: {0}'}"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding Features.ProhibitSendReceiveQuota, StringFormat='{}Prohibit Send/Receive: {0}'}"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- Statistics -->
                    <GroupBox Header="Statistics" Margin="0,0,0,12"
                              Visibility="{Binding Statistics, Converter={StaticResource NullToVisibility}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Size:" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Statistics.TotalItemSize}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Item Count:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Statistics.ItemCount}" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Deleted Items:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,8,0,0">
                                <TextBlock Text="{Binding Statistics.DeletedItemCount, StringFormat='{}{0} items'}"/>
                                <TextBlock Text="{Binding Statistics.TotalDeletedItemSize}"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Last Logon:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding Statistics.LastLogonTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                       Margin="0,8,0,0"/>
                        </Grid>
                    </GroupBox>

                    <!-- Inbox Rules -->
                    <GroupBox Header="Inbox Rules" Margin="0,0,0,12"
                              Visibility="{Binding InboxRules, Converter={StaticResource NullToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="No inbox rules configured"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,8"
                                       Visibility="{Binding InboxRules.Count, Converter={StaticResource ZeroToVisibility}}"/>
                            <ItemsControl ItemsSource="{Binding InboxRules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                    <TextBlock Text=" (Enabled)" Foreground="{StaticResource SuccessBrush}" Margin="8,0,0,0"
                                                               Visibility="{Binding Enabled, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text=" (Disabled)" Foreground="{StaticResource SecondaryTextBrush}" Margin="8,0,0,0"
                                                               Visibility="{Binding Enabled, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                                           Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0"/>

                                                <!-- Forwarding Warning -->
                                                <StackPanel>
                                                    <Border Background="#3D2200" BorderBrush="{StaticResource WarningBrush}"
                                                            BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,4,0,0"
                                                            Visibility="{Binding ForwardTo, Converter={StaticResource NullToVisibility}}">
                                                        <StackPanel>
                                                            <TextBlock Text="⚠ Forwarding Rule Detected" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource WarningBrush}"/>
                                                            <ItemsControl ItemsSource="{Binding ForwardTo}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Foreground="{StaticResource WarningBrush}" Margin="0,2">
                                                                            <Run Text="Forward to: "/><Run Text="{Binding}"/>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Background="#3D2200" BorderBrush="{StaticResource WarningBrush}"
                                                            BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,4,0,0"
                                                            Visibility="{Binding RedirectTo, Converter={StaticResource NullToVisibility}}">
                                                        <StackPanel>
                                                            <TextBlock Text="⚠ Redirect Rule Detected" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource WarningBrush}"/>
                                                            <ItemsControl ItemsSource="{Binding RedirectTo}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Foreground="{StaticResource WarningBrush}" Margin="0,2">
                                                                            <Run Text="Redirect to: "/><Run Text="{Binding}"/>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </GroupBox>

                    <!-- Auto Reply -->
                    <GroupBox Header="Auto-Reply Configuration" Margin="0,0,0,12"
                              Visibility="{Binding AutoReply, Converter={StaticResource NullToVisibility}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Status:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding AutoReply.AutoReplyState}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0"
                                        Visibility="{Binding AutoReply.StartTime, Converter={StaticResource NullToVisibility}}">
                                <TextBlock Text="{Binding AutoReply.StartTime, StringFormat='{}Start: {0:yyyy-MM-dd HH:mm}'}"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding AutoReply.EndTime, StringFormat='{}End: {0:yyyy-MM-dd HH:mm}'}"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                            </StackPanel>
                            <TextBlock Text="Internal Message:" FontWeight="SemiBold" Margin="0,8,0,4"
                                       Visibility="{Binding AutoReply.InternalMessage, Converter={StaticResource NullToVisibility}}"/>
                            <TextBlock Text="{Binding AutoReply.InternalMessage}" TextWrapping="Wrap"
                                       Background="{StaticResource TertiaryBackgroundBrush}" Padding="8"
                                       Visibility="{Binding AutoReply.InternalMessage, Converter={StaticResource NullToVisibility}}"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Permissions Manager -->
                    <GroupBox Header="Permissions Manager" Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Pending Changes Warning -->
                            <Border Background="#3D2200" BorderBrush="{StaticResource WarningBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12"
                                    Visibility="{Binding HasPendingChanges, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding PendingActionsCount, StringFormat='{}⚠ {0} pending changes'}"
                                               FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="Apply Changes" Command="{Binding SavePermissionsCommand}"
                                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                                ToolTip="Apply all pending permission changes to Exchange"/>
                                        <Button Content="Discard" Command="{Binding DiscardPermissionsCommand}"
                                                ToolTip="Cancel all pending changes and reset to current state"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Add New Permission -->
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Labels Row -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="User Email or Name:" FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,8,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Permission Type:" FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,8,4"/>

                                    <!-- Input Controls Row -->
                                    <TextBox Grid.Row="1" Grid.Column="0"
                                             Text="{Binding NewPermissionUser, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,8,0"
                                             ToolTip="Enter user email address or display name"/>

                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              SelectedValue="{Binding NewPermissionType}"
                                              SelectedValuePath="Tag"
                                              Margin="0,0,8,0"
                                              ToolTip="Select permission type to grant">
                                        <ComboBoxItem Content="Full Access" Tag="{x:Static contracts:PermissionType.FullAccess}"/>
                                        <ComboBoxItem Content="Send As" Tag="{x:Static contracts:PermissionType.SendAs}"/>
                                        <ComboBoxItem Content="Send On Behalf" Tag="{x:Static contracts:PermissionType.SendOnBehalf}"/>
                                    </ComboBox>

                                    <ComboBox Grid.Row="1" Grid.Column="2"
                                              SelectedValue="{Binding NewPermissionAutoMapping}"
                                              SelectedValuePath="Tag"
                                              Margin="0,0,8,0"
                                              Width="80"
                                              ToolTip="AutoMapping: automatically adds mailbox to user's Outlook. Only applies to FullAccess permissions.">
                                        <ComboBoxItem Content="True" Tag="True"/>
                                        <ComboBoxItem Content="False" Tag="False"/>
                                    </ComboBox>

                                    <Button Grid.Row="1" Grid.Column="3" Content="Add"
                                            Command="{Binding AddPermissionCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            ToolTip="Add permission to pending changes"/>
                                </Grid>
                            </Border>

                            <!-- FullAccess Permissions -->
                            <TextBlock Text="Full Access Permissions" FontWeight="SemiBold" Margin="0,8,0,4"/>
                            <DataGrid ItemsSource="{Binding FullAccessPermissions}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="{StaticResource SecondaryBackgroundBrush}"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      MaxHeight="200" Margin="0,0,0,12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="User" Binding="{Binding User}" Width="*"/>
                                    <DataGridTemplateColumn Header="AutoMap" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox SelectedValue="{Binding AutoMapping, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Tag"
                                                          Width="75"
                                                          ToolTip="AutoMapping: automatically adds mailbox to user's Outlook">
                                                    <ComboBoxItem Content="True" Tag="True"/>
                                                    <ComboBoxItem Content="False" Tag="False"/>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Inherited" Binding="{Binding IsInherited}" Width="80"/>
                                    <DataGridTemplateColumn Header="Actions" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Content="Applica"
                                                            Command="{Binding DataContext.ModifyAutoMappingCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource PrimaryButton}"
                                                            Padding="6,4"
                                                            Margin="0,0,4,0"
                                                            ToolTip="Apply AutoMapping change"
                                                            Visibility="{Binding IsInherited, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                    <Button Content="Remove"
                                                            Command="{Binding DataContext.RemovePermissionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource DangerButton}"
                                                            Padding="6,4"
                                                            ToolTip="Remove this permission"
                                                            Visibility="{Binding IsInherited, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- SendAs Permissions -->
                            <TextBlock Text="Send As Permissions" FontWeight="SemiBold" Margin="0,8,0,4"/>
                            <DataGrid ItemsSource="{Binding SendAsPermissions}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="{StaticResource SecondaryBackgroundBrush}"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      MaxHeight="200" Margin="0,0,0,12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="User" Binding="{Binding User}" Width="*"/>
                                    <DataGridTextColumn Header="Inherited" Binding="{Binding IsInherited}" Width="80"/>
                                    <DataGridTemplateColumn Header="Actions" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Remove"
                                                        Command="{Binding DataContext.RemovePermissionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DangerButton}"
                                                        Padding="6,4"
                                                        ToolTip="Remove this permission"
                                                        Visibility="{Binding IsInherited, Converter={StaticResource InverseBoolToVisibility}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- SendOnBehalf Permissions -->
                            <TextBlock Text="Send On Behalf Permissions" FontWeight="SemiBold" Margin="0,8,0,4"/>
                            <DataGrid ItemsSource="{Binding SendOnBehalfPermissions}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="{StaticResource SecondaryBackgroundBrush}"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      MaxHeight="200" Margin="0,0,0,12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="User" Binding="{Binding}" Width="*"/>
                                    <DataGridTemplateColumn Header="Actions" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Remove"
                                                        Command="{Binding DataContext.RemovePermissionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DangerButton}"
                                                        Padding="6,4"
                                                        ToolTip="Remove this permission"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Saving Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2" Background="#CC000000"
                Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Saving changes..." HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
