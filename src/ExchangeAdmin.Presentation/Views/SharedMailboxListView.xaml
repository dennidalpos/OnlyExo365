<UserControl x:Class="ExchangeAdmin.Presentation.Views.SharedMailboxListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ExchangeAdmin.Presentation.Views">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <!-- List Panel -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Shared Mailboxes" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SharedMailboxes.StatusText}" Margin="12,0,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Refresh" Command="{Binding SharedMailboxes.RefreshCommand}"
                        Style="{StaticResource PrimaryButton}"/>
                <Button Content="Cancel" Command="{Binding SharedMailboxes.CancelCommand}"
                        Style="{StaticResource DangerButton}"
                        Visibility="{Binding SharedMailboxes.IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Grid>

        <!-- Search and Filter -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search -->
            <TextBox Grid.Column="0" Text="{Binding SharedMailboxes.SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,12,0">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Setter Property="Tag" Value="Search shared mailboxes..."/>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Type Filter -->
            <ComboBox Grid.Column="1" Width="150" SelectedValue="{Binding SharedMailboxes.RecipientTypeFilter}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="User Mailboxes" Tag="UserMailbox"/>
                <ComboBoxItem Content="Shared Mailboxes" Tag="SharedMailbox"/>
                <ComboBoxItem Content="Room Mailboxes" Tag="RoomMailbox"/>
                <ComboBoxItem Content="Equipment" Tag="EquipmentMailbox"/>
                <ComboBoxItem Content="All Types" Tag=""/>
            </ComboBox>
        </Grid>

        <!-- Mailbox List -->
        <Grid Grid.Row="2">
            <!-- List -->
            <DataGrid ItemsSource="{Binding SharedMailboxes.Mailboxes}"
                      SelectedItem="{Binding SharedMailboxes.SelectedMailbox}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="{StaticResource SecondaryBackgroundBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      RowBackground="{StaticResource SecondaryBackgroundBrush}"
                      AlternatingRowBackground="{StaticResource TertiaryBackgroundBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding PrimarySmtpAddress}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding RecipientTypeDetails}" Width="120"/>
                    <DataGridTextColumn Header="Alias" Binding="{Binding Alias}" Width="100"/>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource TertiaryBackgroundBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource TertiaryBackgroundBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
            </DataGrid>

            <!-- Loading Overlay -->
            <Border Background="#80000000"
                    Visibility="{Binding SharedMailboxes.IsLoading, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                    <TextBlock Text="Loading shared mailboxes..." HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Error -->
            <Border Background="#80000000"
                    Visibility="{Binding SharedMailboxes.HasError, Converter={StaticResource BoolToVisibility}}">
                <Border Background="#3D0000" BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="16"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Error" FontWeight="SemiBold" Foreground="{StaticResource ErrorBrush}"/>
                        <TextBlock Text="{Binding SharedMailboxes.ErrorMessage}" TextWrapping="Wrap" MaxWidth="400" Margin="0,4,0,0"/>
                        <Button Content="Retry" Command="{Binding SharedMailboxes.RefreshCommand}" Margin="0,12,0,0"
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

            <!-- Load More -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                <Button Content="Load More" Command="{Binding SharedMailboxes.LoadMoreCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Visibility="{Binding SharedMailboxes.HasMore, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- Details Panel -->
        <views:MailboxDetailsView Grid.Column="2" DataContext="{Binding MailboxDetails}"
                                   Visibility="{Binding HasDetails, FallbackValue=Collapsed, Converter={StaticResource BoolToVisibility}}"/>
    </Grid>
</UserControl>
